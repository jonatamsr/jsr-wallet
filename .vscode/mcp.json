{
  "servers": {
    "github": {
      "type": "stdio",
      "command": "/home/linuxbrew/.linuxbrew/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
      }
    }
  },
  "inputs": [
    {
      "id": "github_token",
      "type": "promptString",
      "description": "GitHub Personal Access Token (com permissões: repo, project, admin:org)",
      "password": true
    }
  ]
}